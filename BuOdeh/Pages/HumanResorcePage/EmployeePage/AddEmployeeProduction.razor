@page "/app/addemployeeproduction"
@using System.Security.Claims
@inject IEmployeeProduction _employeeProduction
@inject IEmployee _employee
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IPrivilege _privilege
@inject NavigationManager navigation
@attribute [Authorize]

<PageTitle>Tambah Produksi Karyawan</PageTitle>

<div class="content">
    <div class="page-header">
        <div class="page-title">
            <h4>Tambah Produksi Karyawan</h4>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            @if (!FormSubmitted)
            {
                <EditForm Model="model" OnValidSubmit="Save">
                    <DataAnnotationsValidator />
                    <div class="row">
                        <!-- Employee Selection -->
                        <div class="col-lg-4 col-sm-6 col-12">
                            <div class="form-group">
                                <label>Pilih Karyawan <span class="text-danger">*</span></label>
                                <select class="form-control" @bind="model.EmployeeID">
                                    <option value="0">-- Pilih Karyawan --</option>
                                    @if (EmployeeList != null)
                                    {
                                        @foreach (var emp in EmployeeList)
                                        {
                                            <option value="@emp.EmployeeId">@emp.EmployeeName</option>
                                        }
                                    }
                                </select>
                                <ValidationMessage For="@(() => model.EmployeeID)" />
                            </div>
                        </div>

                        <!-- Production Date -->
                        <div class="col-lg-4 col-sm-6 col-12">
                            <div class="form-group">
                                <label>Tanggal <span class="text-danger">*</span></label>
                                <RadzenDatePicker @bind-Value="model.InputDate" DateFormat="dd-MM-yyyy" Class="w-100" />
                                <ValidationMessage For="@(() => model.InputDate)" />
                            </div>
                        </div>

                        <!-- Number Produced -->
                        <div class="col-lg-4 col-sm-6 col-12">
                            <div class="form-group">
                                <label>Jumlah Produksi (gunakan titik untuk angka decimal)<span class="text-danger">*</span></label>
                                <input type="number" step="0.01" min="0.01" class="form-control" @bind="model.NumberProduced" placeholder="0.00" />
                                <ValidationMessage For="@(() => model.NumberProduced)" />
                            </div>
                        </div>

                        <div class="col-lg-4 col-sm-6 col-12">
                            <div class="form-group">
                                <label>Pilih Satuan <span class="text-danger">*</span></label>
                                <select class="form-control" @bind="model.Satuan">
                                    <option value="Loyang">Loyang</option>
                                    <option value="Adonan">Adonan</option>
                                    <option value="Oven">Oven</option>
                                </select>                                
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-lg-12">
                            <button type="submit" class="btn btn-submit me-2">
                                <i class="fa fa-save"></i> Simpan Data
                            </button>
                            <button type="button" class="btn btn-cancel" @onclick="Cancel">
                                <i class="fa fa-times"></i> Cancel
                            </button>
                        </div>
                    </div>
                </EditForm>
            }
            else
            {
                <!-- Success Message -->
                <div class="row">
                    <div class="col-lg-12 col-sm-12 col-12">
                        <div class="text-center" style="padding: 20px;">
                            <div class="alert alert-success" role="alert">
                                <h4 class="alert-heading">
                                    <i class="fa fa-check-circle"></i> Berhasil!
                                </h4>
                                <p>Data produksi telah tersimpan.</p>
                                <hr />
                                <p class="mb-0">
                                    <strong>Employee:</strong> @SuccessMessage
                                </p>
                            </div>
                            <button type="button" class="btn btn-primary mt-3 me-2" @onclick="ResetForm">
                                <i class="fa fa-plus"></i> Tambahkan Produksi Lagi
                            </button>                            
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    public Task<AuthenticationState> authenticationState { get; set; }
    EmployeeProduction model = new EmployeeProduction();
    List<EmployeeView> EmployeeList = new List<EmployeeView>();
    bool FormSubmitted = false;
    string SuccessMessage = string.Empty;
    string strMenu = "Add Employee Production";

    protected override async Task OnInitializedAsync()
    {
        var authState = await authenticationState;
        var strRole = authState.User;
        string strName = strRole.FindFirst(ClaimTypes.Role).Value;
        var strShow = await _privilege.PriviliageCheck(strMenu, strName);
        if (strShow.ShowAction == true)
        {
            await LoadData();
        }
        else
        {
            navigation.NavigateTo("/app/dashboard");
            Snackbar.Add("Anda tidak memiliki akses", Severity.Error);
        }
    }

    private async Task LoadData()
    {
        try
        {
            EmployeeList = await _employee.GetAll();

            if (EmployeeList == null || EmployeeList.Count == 0)
            {
                Snackbar.Add("Tidak ada data karyawan.", Severity.Warning);
            }

            model.InputDate = DateTime.Now;
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error data karyawan: " + ex.Message, Severity.Error);
        }
    }

    private async Task Save()
    {
        try
        {
            // Validation
            if (model.EmployeeID == 0)
            {
                Snackbar.Add("Mohon pilih karyawan.", Severity.Warning);
                return;
            }

            if (model.NumberProduced <= 0)
            {
                Snackbar.Add("Angka produksi harus lebih dari 0.", Severity.Warning);
                return;
            }

            model.CreatedBy = 1; // TODO: Get from current user
            model.DateCreated = DateTime.Now;

            var result = await _employeeProduction.Insert(model);

            if (result > 0)
            {
                var employee = EmployeeList.FirstOrDefault(x => x.EmployeeId == model.EmployeeID);
                SuccessMessage = $"{employee?.EmployeeName ?? "Unknown"} - {model.NumberProduced} units on {model.InputDate:yyyy-MM-dd}";

                Snackbar.Add("Data telah berhasil disimpan.", Severity.Success);
                FormSubmitted = true;
                StateHasChanged();
            }
            else
            {
                Snackbar.Add("Gagal menyimpan data.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("System Error: " + ex.Message, Severity.Error);
        }
    }

    private void ResetForm()
    {
        model = new EmployeeProduction();
        model.InputDate = DateTime.Now;
        FormSubmitted = false;
        StateHasChanged();
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/app/employee");
    }
}